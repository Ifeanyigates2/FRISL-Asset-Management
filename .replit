modules = ["dotnet-7.0", "web", "dotnet-8.0"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd FrislEams.Web && DOTNET_CLI_TELEMETRY_OPTOUT=1 dotnet run"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "DOTNET_CLI_TELEMETRY_OPTOUT=1 ./FrislEams.Web/out/FrislEams.Web --urls http://0.0.0.0:5000"]
build = ["bash", "-c", "cd FrislEams.Web && DOTNET_CLI_TELEMETRY_OPTOUT=1 dotnet publish -c Release -o out"]

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>FRISL EAMS</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <header>
        <nav class="top-nav">
            <a asp-controller="Home" asp-action="Index">Home</a>
            <a asp-controller="Assets" asp-action="Index">Assets</a>
            <a asp-controller="Assignments" asp-action="Index">Assignments</a>
            <a asp-controller="Workflow" asp-action="Requests">Requests</a>
            <a asp-controller="Workflow" asp-action="Repairs">Repairs</a>
            <a asp-controller="Workflow" asp-action="Loans">Loans</a>
            <a asp-controller="Workflow" asp-action="Rfid">RFID</a>
            <a asp-controller="Audit" asp-action="Index">Audit</a>
            <a asp-controller="Reports" asp-action="Index">Reports</a>
            <a href="/dashboard">Dashboard</a>
        </nav>
    </header>
    <main class="container">
        @if (TempData["Success"] is string success)
        {
            <div class="alert success">@success</div>
        }
        @if (TempData["Error"] is string error)
        {
            <div class="alert error">@error</div>
        }
        @RenderBody()
    </main>
</body>
</html>

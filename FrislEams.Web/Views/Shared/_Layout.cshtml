<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " – " : "")FRISL EAMS | First Registrars</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <div class="top-bar">
        <span>First Registrars &amp; Investor Services — Enterprise Asset Management System</span>
        <div style="display:flex;gap:1rem;align-items:center;">
            <span>📅 @DateTime.Now.ToString("dd MMM yyyy")</span>
            <a href="/Account/Logout">Sign Out</a>
        </div>
    </div>

    <header class="site-header">
        <div class="header-inner">
            <a asp-controller="Home" asp-action="Index" class="header-logo">
                <img src="~/firstregistrars-logo.png" alt="First Registrars Logo" />
                <div class="system-label">
                    <strong>EAMS</strong>
                    <span>Asset Management System</span>
                </div>
            </a>

            <nav class="main-nav">
                <a asp-controller="Home" asp-action="Index">Home</a>
                <a asp-controller="Assets" asp-action="Index">Assets</a>
                <a asp-controller="Assignments" asp-action="Index">Assignments</a>
                <a asp-controller="Workflow" asp-action="Requests">Requests</a>
                <a asp-controller="Workflow" asp-action="Repairs">Repairs</a>
                <a asp-controller="Workflow" asp-action="Loans">Loans</a>
                <a asp-controller="Workflow" asp-action="Rfid">RFID</a>
                <a asp-controller="Audit" asp-action="Index">Audit</a>
                <a asp-controller="Reports" asp-action="Index">Reports</a>
                <a href="/dashboard">Dashboard</a>
            </nav>

            <div class="nav-actions">
                @{
                    var sessionUser = Context.Session.GetString("UserName") ?? "Admin";
                    var sessionRole = Context.Session.GetString("UserRole") ?? "Admin";
                    var initials = string.Concat(sessionUser.Split(' ').Take(2).Select(w => w[0])).ToUpper();
                }
                <div class="nav-user">
                    <div class="avatar">@initials</div>
                    <div>
                        <div style="font-size:0.8rem;font-weight:600;color:#fff;line-height:1.2;">@sessionUser</div>
                        <div style="font-size:0.7rem;color:rgba(255,255,255,0.55);line-height:1;">@sessionRole</div>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <div class="content-wrapper">
        <main class="container">
            @if (TempData["Success"] is string success)
            {
                <div class="alert success">✅ @success</div>
            }
            @if (TempData["Error"] is string error)
            {
                <div class="alert error">⚠️ @error</div>
            }
            @RenderBody()
        </main>
    </div>

    <footer class="site-footer">
        <div style="display:flex;align-items:center;gap:0.75rem;">
            <img src="~/firstregistrars-logo.png" alt="First Registrars" class="footer-logo" />
            <span>&copy; @DateTime.Now.Year First Registrars &amp; Investor Services Ltd. All rights reserved.</span>
        </div>
        <span>Enterprise Asset Management System v1.0</span>
    </footer>
</body>
</html>

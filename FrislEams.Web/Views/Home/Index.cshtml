<h1>FRISL Enterprise Asset Management</h1>

<div class="cards-grid">
    <div class="metric-card">
        <h3>Total Assets</h3>
        <p>@ViewBag.TotalAssets</p>
    </div>
    <div class="metric-card">
        <h3>Pending Assignment Confirmations</h3>
        <p>@ViewBag.PendingAssignments</p>
    </div>
    <div class="metric-card">
        <h3>RFID Exit Alerts</h3>
        <p>@ViewBag.Alerts</p>
    </div>
</div>

<p class="mt">Use the navigation menu to register assets, run assignment workflows, process repairs/loans, and monitor RFID events.</p>

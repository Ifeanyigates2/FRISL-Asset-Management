@model List<AuditSession>
@{
    var departments = ViewBag.Departments as List<Department> ?? new();
    var assets = ViewBag.Assets as List<Asset> ?? new();
    int? activeSessionId = ViewBag.ActiveSessionId is int sid ? sid : null;
}

<h1>Audit Framework</h1>

<form asp-action="Start" method="post" class="form-grid">
    @Html.AntiForgeryToken()
    <label>Audit Type</label>
    <select name="AuditType">
        <option>Departmental</option>
        <option>Independent</option>
    </select>

    <label>Department (Optional)</label>
    <select name="DepartmentId">
        <option value="">-- Optional --</option>
        @foreach (var d in departments)
        {
            <option value="@d.Id">@d.Name</option>
        }
    </select>

    <label>Initiated By</label>
    <input name="InitiatedBy" value="Auditor" required />

    <button class="btn" type="submit">Start Audit Session</button>
</form>

@if (activeSessionId.HasValue)
{
    <h2>Submit Scan/Count Result (Session @activeSessionId.Value)</h2>
    <form asp-action="SubmitResult" method="post" class="form-grid">
        @Html.AntiForgeryToken()
        <input type="hidden" name="AuditSessionId" value="@activeSessionId.Value" />

        <label>Asset</label>
        <select name="AssetId">
            @foreach (var a in assets)
            {
                <option value="@a.Id">@a.TagCode - @a.AssetName</option>
            }
        </select>

        <label>Seen Status</label>
        <select name="SeenStatus">
            <option>Seen</option>
            <option>Missing</option>
            <option>Misplaced</option>
        </select>

        <label>Physical Condition</label>
        <input name="PhysicalCondition" />

        <label>Notes</label>
        <textarea name="Notes"></textarea>

        <button class="btn" type="submit">Submit Result</button>
    </form>
}

<table>
    <thead>
        <tr><th>ID</th><th>Type</th><th>Department</th><th>Status</th><th>Started</th><th>Actions</th></tr>
    </thead>
    <tbody>
    @foreach (var s in Model)
    {
        <tr>
            <td>@s.Id</td>
            <td>@s.AuditType</td>
            <td>@s.Department?.Name</td>
            <td>@s.Status</td>
            <td>@s.StartDate.ToLocalTime()</td>
            <td>
                <a asp-action="Index" asp-route-id="@s.Id">Open</a>
                <a asp-action="Variance" asp-route-id="@s.Id">Variance</a>
                @if (s.Status == "Open")
                {
                    <form asp-action="Close" method="post" class="inline-form">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@s.Id" />
                        <button class="btn" type="submit">Close</button>
                    </form>
                }
            </td>
        </tr>
    }
    </tbody>
</table>

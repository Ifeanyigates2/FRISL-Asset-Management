@model List<AuditSession>
@{
    ViewData["Title"] = "Audit Framework";
    var departments = ViewBag.Departments as List<Department> ?? new();
    var assets = ViewBag.Assets as List<Asset> ?? new();
    int? activeSessionId = ViewBag.ActiveSessionId is int sid ? sid : null;
    var openSessions = Model.Where(s => s.Status == "Open").ToList();
    var closedSessions = Model.Where(s => s.Status == "Closed").ToList();
}

<div class="page-header">
    <div class="page-title">
        <h1>Audit Framework</h1>
        <p class="page-subtitle">Physical verification, variance analysis, and audit trail management</p>
    </div>
    <div class="flex-gap">
        <span class="badge @(openSessions.Any() ? "badge-warning" : "badge-success")">@openSessions.Count Open Session@(openSessions.Count != 1 ? "s" : "")</span>
        <span class="badge badge-muted">@closedSessions.Count Closed</span>
    </div>
</div>

<!-- Start New Audit Session -->
<div class="collapsible-section">
    <div class="collapsible-header" onclick="toggleSection('auditFormBody')">
        <h3>+ Start New Audit Session</h3>
        <span class="chevron">▼</span>
    </div>
    <div class="collapsible-body" id="auditFormBody" style="display:none;">
        <form asp-action="Start" method="post" class="form-inline-grid">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label class="form-label required">Audit Type</label>
                <select name="AuditType" class="form-control">
                    <option value="Departmental">Departmental</option>
                    <option value="Full Physical">Full Physical Inventory</option>
                    <option value="Spot Check">Spot Check</option>
                    <option value="Independent">Independent (External)</option>
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Department (Optional)</label>
                <select name="DepartmentId" class="form-control">
                    <option value="">-- All Departments / Independent --</option>
                    @foreach (var d in departments)
                    {
                        <option value="@d.Id">@d.Name (@d.Code)</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label class="form-label required">Initiated By</label>
                <input name="InitiatedBy" class="form-control" required value="@(Context.Session.GetString("UserName") ?? "Auditor")" />
            </div>
            <div class="form-group">
                <label class="form-label">Notes</label>
                <input name="Notes" class="form-control" placeholder="Optional audit notes or scope..." />
            </div>
            <div style="grid-column:1/-1;">
                <button type="submit" class="btn btn-primary">Start Audit Session</button>
            </div>
        </form>
    </div>
</div>

<!-- Active Session: Submit Results -->
@if (activeSessionId.HasValue)
{
    var activeSession = Model.FirstOrDefault(s => s.Id == activeSessionId.Value);
    <div class="info-card" style="border-left:4px solid #1d3461;margin-top:1.5rem;background:#f7f9ff;">
        <div class="info-card-header">
            <h3 style="color:#1d3461;">Record Asset Scan — Session #@activeSessionId.Value</h3>
            @if (activeSession != null)
            {
                <span class="badge badge-info">@activeSession.AuditType · @(activeSession.Department?.Name ?? "All Depts")</span>
            }
        </div>
        <form asp-action="SubmitResult" method="post" class="form-inline-grid" style="margin-top:1rem;">
            @Html.AntiForgeryToken()
            <input type="hidden" name="AuditSessionId" value="@activeSessionId.Value" />
            <div class="form-group">
                <label class="form-label required">Asset</label>
                <select name="AssetId" class="form-control" required>
                    <option value="">-- Select Asset --</option>
                    @foreach (var a in assets)
                    {
                        <option value="@a.Id">@a.TagCode — @a.AssetName</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Seen Status</label>
                <select name="SeenStatus" class="form-control">
                    <option value="Seen">Seen – Present at expected location</option>
                    <option value="Missing">Missing – Not found</option>
                    <option value="Misplaced">Misplaced – Found at different location</option>
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Physical Condition Observed</label>
                <select name="PhysicalCondition" class="form-control">
                    <option value="">-- Not checked --</option>
                    <option value="Good">Good</option>
                    <option value="Fair">Fair</option>
                    <option value="Poor">Poor</option>
                    <option value="Damaged">Damaged</option>
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Notes / Variance Description</label>
                <input name="Notes" class="form-control" placeholder="Any observations..." />
            </div>
            <div style="grid-column:1/-1;">
                <button type="submit" class="btn btn-primary">Record Result</button>
                <a asp-action="Variance" asp-route-id="@activeSessionId.Value" class="btn btn-outline" style="margin-left:0.5rem;">View Variance Report</a>
            </div>
        </form>
    </div>
}

<!-- Open Sessions -->
@if (openSessions.Any())
{
    <div class="table-card" style="margin-top:1.5rem;">
        <div class="table-header-bar">
            <h3 style="font-size:1rem;font-weight:600;color:#856404;">Open Audit Sessions</h3>
        </div>
        <table class="data-table">
            <thead>
                <tr><th>ID</th><th>Type</th><th>Department</th><th>Initiated By</th><th>Started</th><th>Notes</th><th>Actions</th></tr>
            </thead>
            <tbody>
            @foreach (var s in openSessions)
            {
                <tr>
                    <td>#@s.Id</td>
                    <td><span class="badge badge-info">@s.AuditType</span></td>
                    <td>@(s.Department?.Name ?? "All Departments")</td>
                    <td>@s.InitiatedBy</td>
                    <td style="font-size:0.82rem;">@s.StartDate.ToString("dd MMM yyyy, HH:mm")</td>
                    <td style="font-size:0.82rem;">@(s.Notes ?? "—")</td>
                    <td>
                        <div class="action-links">
                            <a asp-action="Index" asp-route-id="@s.Id" class="btn btn-xs btn-primary">Record Scans</a>
                            <a asp-action="Variance" asp-route-id="@s.Id" class="btn btn-xs btn-outline">Variance</a>
                            <form asp-action="Close" method="post" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@s.Id" />
                                <button class="btn btn-xs btn-danger" type="submit" onclick="return confirm('Close this audit session?')">Close</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}

<!-- Closed Sessions -->
@if (closedSessions.Any())
{
    <div class="table-card" style="margin-top:1.5rem;">
        <div class="table-header-bar">
            <h3 style="font-size:1rem;font-weight:600;color:#1d3461;">Closed Audit Sessions</h3>
        </div>
        <table class="data-table">
            <thead>
                <tr><th>ID</th><th>Type</th><th>Department</th><th>Initiated By</th><th>Start Date</th><th>End Date</th><th>Report</th></tr>
            </thead>
            <tbody>
            @foreach (var s in closedSessions.OrderByDescending(x => x.EndDate))
            {
                <tr>
                    <td>#@s.Id</td>
                    <td><span class="badge badge-muted">@s.AuditType</span></td>
                    <td>@(s.Department?.Name ?? "All Departments")</td>
                    <td>@s.InitiatedBy</td>
                    <td style="font-size:0.82rem;">@s.StartDate.ToString("dd MMM yyyy")</td>
                    <td style="font-size:0.82rem;">@(s.EndDate?.ToString("dd MMM yyyy") ?? "—")</td>
                    <td>
                        <a asp-action="Variance" asp-route-id="@s.Id" class="btn btn-xs btn-outline">View Report</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}

@if (!Model.Any())
{
    <div class="empty-state-card" style="margin-top:1.5rem;">No audit sessions have been started yet.</div>
}

<script>
function toggleSection(id) {
    var el = document.getElementById(id);
    el.style.display = el.style.display === 'none' ? 'block' : 'none';
}
</script>

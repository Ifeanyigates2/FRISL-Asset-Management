@model List<AssetStatusHistory>
@{
    var asset = ViewBag.Asset as Asset;
    ViewData["Title"] = "Status History";
}

<div class="page-header">
    <div class="page-title">
        <h1>Status History</h1>
        <p class="page-subtitle">@asset?.TagCode — @asset?.AssetName</p>
    </div>
    <div class="flex-gap">
        <a asp-action="Detail" asp-route-id="@asset?.Id" class="btn btn-outline">← Asset Detail</a>
        <a asp-action="Index" class="btn btn-outline">All Assets</a>
    </div>
</div>

<div class="table-card">
    <div class="table-header-bar">
        <span>@Model.Count status event@(Model.Count != 1 ? "s" : "") recorded</span>
    </div>
    <table class="data-table">
        <thead>
            <tr>
                <th>Date &amp; Time</th>
                <th>Previous Status</th>
                <th>New Status</th>
                <th>Reason</th>
                <th>Changed By</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td style="white-space:nowrap;color:#555;font-size:0.85rem;">@item.ChangedAt.ToString("dd MMM yyyy, HH:mm")</td>
                <td><span class="badge badge-muted" style="font-size:0.78rem;">@item.PreviousStatus</span></td>
                <td><span class="badge badge-info" style="font-size:0.78rem;">@item.NewStatus</span></td>
                <td>@item.Reason</td>
                <td>@item.ChangedBy</td>
            </tr>
        }
        @if (!Model.Any())
        {
            <tr><td colspan="5" class="empty-state">No status history found.</td></tr>
        }
        </tbody>
    </table>
</div>

@model RepairContractor
@{
    ViewData["Title"] = "Add Contractor";
}

<div class="page-header">
    <div class="page-title">
        <h1>Register Repair Contractor</h1>
        <p class="page-subtitle">Add a new contractor to the approved vendors list for repair assignments.</p>
    </div>
    <a asp-action="Index" class="btn btn-outline">← Back to Contractors</a>
</div>

<form asp-action="Create" method="post" class="form-card">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="alert alert-error"></div>

    <div class="form-section">
        <h3 class="form-section-title">Company Information</h3>
        <div class="form-grid-2">
            <div class="form-group">
                <label asp-for="Name" class="form-label required">Company Name</label>
                <input asp-for="Name" class="form-control" placeholder="e.g. TechFix Solutions Ltd" required />
                <span asp-validation-for="Name" class="field-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="Code" class="form-label required">Contractor Code</label>
                <input asp-for="Code" class="form-control" placeholder="e.g. CON-001" required />
                <div class="field-hint">Unique identifier for this contractor</div>
                <span asp-validation-for="Code" class="field-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="Specialisation" class="form-label required">Specialisation</label>
                <select asp-for="Specialisation" class="form-control">
                    <option value="IT Equipment">IT Equipment</option>
                    <option value="HVAC">HVAC &amp; Climate Control</option>
                    <option value="Electrical">Electrical Systems</option>
                    <option value="Mechanical">Mechanical / General</option>
                    <option value="Office Furniture">Office Furniture &amp; Fittings</option>
                    <option value="Networking">Networking &amp; Telecoms</option>
                    <option value="Security Systems">Security Systems &amp; CCTV</option>
                    <option value="Vehicles">Vehicles &amp; Fleet</option>
                    <option value="General Maintenance">General Maintenance</option>
                    <option value="Other">Other</option>
                </select>
            </div>
            <div class="form-group">
                <label asp-for="SlaHours" class="form-label">SLA Response (Hours)</label>
                <select asp-for="SlaHours" class="form-control">
                    <option value="4">4 hours (Emergency)</option>
                    <option value="8">8 hours (Same Day)</option>
                    <option value="24">24 hours (Next Day)</option>
                    <option value="48" selected>48 hours (Standard)</option>
                    <option value="72">72 hours (Extended)</option>
                </select>
            </div>
        </div>
    </div>

    <div class="form-section">
        <h3 class="form-section-title">Contact Details</h3>
        <div class="form-grid-2">
            <div class="form-group">
                <label asp-for="ContactPerson" class="form-label">Primary Contact Person</label>
                <input asp-for="ContactPerson" class="form-control" placeholder="Contact name" />
            </div>
            <div class="form-group">
                <label asp-for="Phone" class="form-label">Phone Number</label>
                <input asp-for="Phone" class="form-control" placeholder="+234 800 000 0000" />
            </div>
            <div class="form-group" style="grid-column:1/-1;">
                <label asp-for="Email" class="form-label">Email Address</label>
                <input asp-for="Email" type="email" class="form-control" placeholder="contact@company.com" />
            </div>
        </div>
    </div>

    <div class="form-actions">
        <button type="submit" class="btn btn-primary btn-lg">Add Contractor</button>
        <a asp-action="Index" class="btn btn-outline btn-lg">Cancel</a>
    </div>
</form>
